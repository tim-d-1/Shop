@page
@model InternetShop.Pages.Cart.IndexModel
@{
    ViewData["Title"] = "Shopping Cart";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="fa-solid fa-cart-shopping text-primary"></i> Your Shopping Cart</h2>

    @if (Model.CartItems.Count == 0)
    {
        <div class="alert alert-secondary text-center py-5" role="alert">
            <h4 class="alert-heading">Your cart is empty!</h4>
            <p>Looks like you haven't added anything to your cart yet.</p>
            <hr>
            <a asp-page="/Index" class="btn btn-primary">Return to Catalog</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle shadow-sm">
                <thead class="table-dark">
                    <tr>
                        <th scope="col" style="width: 15%">Product</th>
                        <th scope="col" style="width: 40%">Name</th>
                        <th scope="col">Price</th>
                        <th scope="col">Quantity</th>
                        <th scope="col">Subtotal</th>
                        <th scope="col"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.CartItems)
                    {
                        var subtotal = item.Product!.Price * item.Quantity;
                        <tr>
                            <td>
                                <img src="@(string.IsNullOrEmpty(item.Product.ImageUrl) ? $"https://placehold.co/100x100/212529/FFFFFF?text={item.Product.Name.Substring(0, 3)}" : item.Product.ImageUrl)"
                                     class="img-thumbnail" alt="@item.Product.Name" style="max-width: 80px;">
                            </td>
                            <td class="fw-bold">@item.Product.Name</td>
                            <td>$@item.Product.Price.ToString("F2")</td>
                            <td>@item.Quantity</td>
                            <td class="fw-bold text-success">$@subtotal.ToString("F2")</td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="Remove" asp-route-id="@item.Id">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="fa-solid fa-trash"></i> Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="row mt-4">
            <div class="col-md-6 offset-md-6">
                <div class="card border-primary shadow-sm">
                    <div class="card-body">
                        <h4 class="card-title">Order Summary</h4>
                        <hr />
                        <div class="d-flex justify-content-between mb-3">
                            <span class="fs-5">Total (Fiat):</span>
                            <span class="fs-5 fw-bold text-success">$@Model.TotalFiatPrice.ToString("F2")</span>
                        </div>

                        <div class="d-flex justify-content-between mb-4">
                            <span class="fs-5 text-muted">Estimated ETH:</span>
                            <span class="fs-5 fw-bold text-primary" id="ethTotal">Calculating...</span>
                        </div>

                        <div class="d-grid">
                            <button class="btn btn-primary btn-lg" id="btnCheckout" disabled>
                                <i class="fa-brands fa-ethereum"></i> Pay with Ethereum
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <form id="checkoutForm" method="post" asp-page="/Cart/Index" asp-page-handler="Checkout">
        <input type="hidden" id="txHash" name="transactionHash" value="" />
    </form>

    @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/web3@latest/dist/web3.min.js"></script>

        <script>
            document.addEventListener("DOMContentLoaded", async function () {
            const fiatTotal = @Model.TotalFiatPrice.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const ethTotalElement = document.getElementById("ethTotal");
            const checkoutBtn = document.getElementById("btnCheckout");


            if (fiatTotal > 0) {
                try {
                const response = await fetch('?handler=EthPrice');
                const data = await response.json();
                const ethAmount = fiatTotal / data.usdRate;

                ethTotalElement.innerHTML = `${ethAmount.toFixed(5)} ETH <br><small class='text-muted'>(Rate: $${data.usdRate}/ETH)</small>`;
                checkoutBtn.dataset.ethAmount = ethAmount.toFixed(5);
                checkoutBtn.disabled = false;
                checkoutBtn.classList.replace("btn-primary", "btn-success");

                } catch (error) {
                ethTotalElement.innerText = "Error loading live ETH rate.";
                console.error(error);
                }
            } else {
                if (ethTotalElement) {
                    ethTotalElement.innerText = "0.0000 ETH";
                }
            }

            checkoutBtn.addEventListener("click", async function () {
                if (typeof window.ethereum !== 'undefined') {
                    try {
                        checkoutBtn.disabled = true;
                        checkoutBtn.innerHTML = "<i class='fa-solid fa-spinner fa-spin'></i> Waiting for MetaMask...";

                        const web3 = new Web3(window.ethereum);
                        const contractAddress = "@Model.ContractAddress";
                        const contractABI = @Html.Raw(Model.ContractABI);
                        const shopContract = new web3.eth.Contract(contractABI, contractAddress);

                        const accounts = await web3.eth.requestAccounts();
                        const userAddress = accounts[0];

                        const ethAmountToPay = checkoutBtn.dataset.ethAmount;
                        const weiAmount = web3.utils.toWei(ethAmountToPay, 'ether');

                        const tempOrderId = Date.now();

                        const receipt = await shopContract.methods.payForOrder(tempOrderId).send({
                        from: userAddress,
                        value: weiAmount
                    });

                    document.getElementById("txHash").value = receipt.transactionHash;
                    document.getElementById("checkoutForm").submit();

                } catch (error) {
                    console.error("Transaction Error: ", error);
                    checkoutBtn.disabled = false;
                    checkoutBtn.innerHTML = "<i class='fa-brands fa-ethereum'></i> Pay with Ethereum";
                    alert("Contract execution failed or was rejected.");
                }
            } else {
                alert("Please install MetaMask to proceed.");
            }
            });
            });
        </script>
    }
</div>