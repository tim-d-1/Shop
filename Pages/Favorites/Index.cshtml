@page
@model InternetShop.Pages.Favorites.IndexModel
@{
    ViewData["Title"] = "My Favorites";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="fa-solid fa-heart text-danger"></i> Your Favorites</h2>

    @if (!Model.WishlistItems.Any())
    {
        <div class="alert alert-secondary text-center py-5">
            <h4 class="alert-heading">Your wishlist is empty!</h4>
            <p>Go back to the catalog and add some products you like.</p>
            <hr>
            <a asp-page="/Index" class="btn btn-primary">Return to Catalog</a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var item in Model.WishlistItems)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-secondary">
                        <img src="@(string.IsNullOrEmpty(item.Product!.ImageUrl) ? $"https://placehold.co/600x400/212529/FFFFFF?text={item.Product.Name}" : item.Product.ImageUrl)"
                             class="card-img-top" alt="@item.Product.Name">

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@item.Product.Name</h5>
                            <p class="card-text text-muted flex-grow-1">@item.Product.Description</p>

                            <div class="mb-3">
                                <span class="fs-4 fw-bold text-success">$@item.Product.Price.ToString("F2")</span>
                            </div>

                            <div class="d-flex justify-content-between mt-auto">
                                <form method="post" asp-page="/Favorites/Remove" asp-route-id="@item.ProductId" class="d-inline"
                                      asp-route-returnUrl="@HttpContext.Request.Path">
                                    <button type="submit" class="btn btn-outline-danger" title="Remove from Favorites">
                                        <i class="fa-solid fa-trash"></i> Remove
                                    </button>
                                </form>

                                <form method="post" asp-page="/Cart/Add" asp-route-id="@item.ProductId">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="fa-solid fa-cart-plus"></i> Add to Cart
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>