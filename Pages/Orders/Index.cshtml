@page
@model InternetShop.Pages.Orders.IndexModel
@{
    ViewData["Title"] = "My Orders";
}

<div class="container mt-4">
    <h2 class="mb-4"><i class="fa-solid fa-box-open text-primary"></i> Order History</h2>

    @if (!Model.Orders.Any())
    {
        <div class="alert alert-secondary text-center py-5" role="alert">
            <h4 class="alert-heading">No orders yet!</h4>
            <p>You haven't made any purchases with Ethereum yet.</p>
            <hr>
            <a asp-page="/Index" class="btn btn-primary">Go to Catalog</a>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var order in Model.Orders)
            {
                <div class="col-12 mb-4">
                    <div class="card shadow-sm border-secondary">
                        <div class="card-header bg-dark d-flex justify-content-between align-items-center">
                            <div>
                                <span class="fw-bold">Order #@order.Id</span>
                                <span class="text-muted ms-2">@order.OrderDate.ToLocalTime().ToString("f")</span>
                            </div>
                            <div>
                                <span class="badge bg-primary">
                                    Status: @order.Status
                                </span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <p class="mb-1"><strong>Total Paid (Fiat):</strong> <span class="text-success">$@order.TotalPrice.ToString("F2")</span></p>
                                    <p class="mb-1"><strong>Total Paid (ETH):</strong> <i class="fa-brands fa-ethereum text-primary"></i> @order.TotalEthAmount.ToString("F5")</p>
                                </div>
                                <div class="col-md-6 text-md-end">
                                    <p class="mb-1 text-muted">Transaction Hash:</p>
                                    <a href="https://sepolia.etherscan.io/tx/@order.TransactionHash" target="_blank" class="text-info text-break" title="View on Blockchain">
                                        @order.TransactionHash <i class="fa-solid fa-arrow-up-right-from-square ms-1"></i>
                                    </a>
                                </div>
                            </div>

                            <h6 class="text-muted border-bottom pb-2">Items in this order:</h6>
                            <div class="table-responsive">
                                <table class="table table-sm table-borderless align-middle mb-0">
                                    <tbody>
                                        @foreach (var item in order.OrderItems)
                                        {
                                            <tr>
                                                <td style="width: 60px;">
                                                    <img src="@(string.IsNullOrEmpty(item.Product?.ImageUrl) ? $"https://placehold.co/50x50/212529/FFFFFF?text={item.Product?.Name.Substring(0, 3)}" : item.Product?.ImageUrl)" 
                                                         class="img-thumbnail border-secondary" alt="@item.Product?.Name" style="max-width: 50px;">
                                                </td>
                                                <td>@item.Product?.Name</td>
                                                <td class="text-muted">@item.Quantity x $@item.PriceAtPurchase.ToString("F2")</td>
                                                <td class="text-end fw-bold">$@((item.Quantity * item.PriceAtPurchase).ToString("F2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>